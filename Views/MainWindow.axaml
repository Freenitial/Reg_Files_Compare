<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RegCompare.ViewModels"
        xmlns:views="clr-namespace:RegCompare.Views"
        mc:Ignorable="d"
        x:Class="RegCompare.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="REG Files Compare"
        Icon="/Assets/logo.ico"
        Width="1110" Height="700"
        MinWidth="900" MinHeight="540"
        Background="{DynamicResource RegRootBackground}"
        Foreground="{DynamicResource RegForeground}"
        FontSize="12"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="55,30,22,*,22">

        <!-- 1. Loaded files list -->
        <Border Grid.Row="0"
                Background="{DynamicResource RegPanelBackground}"
                BorderBrush="{DynamicResource RegBorder}"
                BorderThickness="1">
            <Grid>
                <!-- Progress fill that grows left-to-right while a Compare is running -->
                <ProgressBar Classes="background-fill"
                             Value="{Binding ComparisonProgress}"
                             Minimum="0" Maximum="1"
                             IsVisible="{Binding IsComparing}"
                             ShowProgressText="False" />
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LoadedFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:LoadedFileViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <CheckBox IsChecked="{Binding IsChecked}"
                                          VerticalAlignment="Center"
                                          MinHeight="18" />
                                <Button Classes="close"
                                        Content="X"
                                        Width="16" Height="16"
                                        FontSize="10"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Remove this file"
                                        Command="{Binding RemoveCommand}" />
                                <TextBlock Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 2. Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource RegSecondaryPanel}">
            <DockPanel Margin="5,4" LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="Browse .reg Files"
                        Click="OnBrowseClick"
                        FontWeight="Bold"
                        Width="120" />
                <TextBlock DockPanel.Dock="Left"
                           Text="Reference:"
                           VerticalAlignment="Center"
                           Margin="15,0,4,0" />
                <ComboBox DockPanel.Dock="Left"
                          ItemsSource="{Binding LoadedFiles}"
                          SelectedItem="{Binding ReferenceFile}"
                          Width="170"
                          Margin="0,0,15,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:LoadedFileViewModel">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Right-side controls (added first = rightmost) -->
                <Button DockPanel.Dock="Right"
                        Content="Compare"
                        Command="{Binding CompareCommand}"
                        FontWeight="Bold"
                        Width="100" />
                <Button DockPanel.Dock="Right"
                        Content="Collapse All"
                        Command="{Binding CollapseAllCommand}"
                        Width="90"
                        Margin="0,0,4,0" />
                <Button DockPanel.Dock="Right"
                        Content="Expand All"
                        Command="{Binding ExpandAllCommand}"
                        Width="80"
                        Margin="0" />
                <CheckBox DockPanel.Dock="Right"
                          Content="Dark Theme"
                          IsChecked="{Binding Theme.IsDark}"
                          Margin="0,0,10,0" />
                <CheckBox DockPanel.Dock="Right"
                          Content="Show only changes"
                          IsChecked="{Binding ShowOnlyChanges}"
                          Margin="0,0,10,0" />
                <CheckBox DockPanel.Dock="Right"
                          Content="Hide empty added nodes"
                          IsChecked="{Binding HideEmptyAddedNodes}"
                          Margin="0,0,10,0" />
            </DockPanel>
        </Border>

        <!-- 3. Search box -->
        <Border Grid.Row="2" Background="{DynamicResource RegSecondaryPanel}">
            <Grid Margin="5,1" ColumnDefinitions="Auto,10,*">
                <TextBlock Grid.Column="0"
                           Text="Search (press Enter):"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="2"
                         Text="{Binding SearchTerm}"
                         KeyDown="OnSearchKeyDown" />
            </Grid>
        </Border>

        <!-- 4. Columns area + drop overlay -->
        <Grid Grid.Row="3" Background="{DynamicResource RegRootBackground}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.DataTemplates>
                        <DataTemplate DataType="vm:FileColumnViewModel">
                            <views:FileColumnView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SearchColumnViewModel">
                            <views:SearchColumnView />
                        </DataTemplate>
                    </ItemsControl.DataTemplates>
                </ItemsControl>
            </ScrollViewer>

            <Border IsHitTestVisible="False"
                    IsVisible="{Binding IsDropHintVisible}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                <TextBlock Text="Drop .reg files here"
                           FontSize="24"
                           FontWeight="Bold"
                           Opacity="0.45"
                           Foreground="{DynamicResource RegForeground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <!-- 5. Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource RegSecondaryPanel}"
                BorderBrush="{DynamicResource RegBorder}"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center" />
        </Border>

    </Grid>

</Window>
